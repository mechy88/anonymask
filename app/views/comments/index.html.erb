<!-- app/views/comments/index.html.erb -->
<h1>Comments</h1>

<% @comments.each do |comment| %>
  <div class="border p-2 mb-2 rounded">
    <strong><%= comment.user.display_name(Current.user) %></strong>: 
    <%= comment.content %>
    
    <% if can_manage_comment?(comment) %>
      <div class="mt-1">
        <%= link_to "Edit", edit_comment_path(comment), class: "btn btn-sm btn-secondary" %>
        <%= button_to "Delete", comment_path(comment), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
      </div>
    <% end %>
  </div>
<% end %>
