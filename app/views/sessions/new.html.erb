<div class="container mt-5">
  <div class="text-center my-3 mb-5">
    <%= image_tag "Logo.png", class: "img-fluid w-25", alt: "Anonymask Logo" %>
  </div>

  <div class="card shadow-sm mx-auto" style="max-width: 700px; width: 100%;">
    <div class="card-body">
      <h2 class="card-title text-center">Welcome Back</h2>

      <p class="text-center text-muted fs-6">Join your team's anonymous feedback platform</p>

      <%= form_with model: @user, url: session_path, class: "mt-4" do |form| %>
        <div class="mb-4">
          <%= form.label :email, class: "form-label fs-5" %>
          <%= form.email_field :email, class: "form-control fs-5", placeholder: "Enter your email" %>
        </div>

        <div class="mb-3">
          <%= form.label :password, class: "form-label fs-5" %>
          <%= form.password_field :password, class: "form-control fs-5", placeholder: "Enter your password" %>
        </div>

        <div class="text-left mt-4 mb-3">
          <%= link_to "Forgot password?", "#", class: "text-decoration-none" %>
        </div>

        <div class="d-grid gap-2">
          <%= form.submit "Login", class: "btn btn-dark btn-lg" %>
        </div>
      <% end %>
        <p class="text-center text-muted fs-6 mt-4">Don't have and account? <%= link_to "Sign up", new_registration_path, class: "text-decoration-none" %></p>
    </div>
  </div>
</div>
