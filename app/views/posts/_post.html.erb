<div class="card mb-4 shadow-sm p-3">
  <!-- Title and Author beside each other -->
  <div class="d-flex align-items-center mb-1">
    <h5 class="card-title text-primary mb-0 me-2">
      <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
    </h5>

    <% if post.user == Current.user %>
      <!-- Show only the "You" badge -->
      <span class="badge bg-primary ms-2" style="font-size: 0.75rem;">You</span>
    <% else %>
      <!-- Everyone else (including admins) sees 👤 Anonymous only -->
      <span class="text-muted" style="font-size: 0.875rem;">👤 Anonymous</span>
    <% end %>
  </div>

  <!-- Timestamp -->
  <p class="text-muted mb-2" style="font-size: 0.875rem;">
    ⏱️ Posted <%= time_ago_in_words(post.created_at) %> ago
  </p>

  <!-- Post Content with See More / See Less -->
  <div class="card-text text-muted mb-2">
    <% if post.content.length > 150 %>
      <div id="truncated-<%= post.id %>">
        <%= truncate(post.content, length: 150, separator: ' ', omission: '...') %>
        <a href="#" onclick="toggleContent(<%= post.id %>); return false;" class="text-primary fw-semibold">See more</a>
      </div>

      <div id="full-<%= post.id %>" style="display: none;">
        <%= simple_format(post.content) %>
        <a href="#" onclick="toggleContent(<%= post.id %>); return false;" class="text-primary fw-semibold">See less</a>
      </div>
    <% else %>
      <div>
        <%= simple_format(post.content) %>
      </div>
    <% end %>
  </div>

  <!-- Reactions and comment count row -->
  <% @reactions = post.reactions %>
  <% if user_signed_in? %>
    <% @reaction = @reactions.find_by(user_id: current_user.id) %>
    <div class="d-flex align-items-center justify-content-between mt-3">
      <!-- Reactions -->
      <div class="flex-grow-1">
        <%= render partial: "reaction", locals: { post: post, reactions: @reactions, reaction: @reaction } %>
      </div>

      <!-- Comment count -->
      <div class="ms-3 text-muted" style="white-space: nowrap;">
        💬 <%= pluralize(post.comments.count, "comment") %>
      </div>
    </div>
  <% end %>

  <!-- Latest Comment Previews -->
  <% if post.comments.any? %>
    <div class="mt-3 border-top pt-2">
      <% post.comments.last(2).each do |comment| %>
        <p class="text-muted small mb-1">
          💬 <%= truncate(comment.content, length: 100) %>
        </p>
      <% end %>
    </div>
  <% end %>
</div>

<!-- JavaScript for toggle -->
<script>
  function toggleContent(postId) {
    const truncated = document.getElementById(`truncated-${postId}`);
    const full = document.getElementById(`full-${postId}`);

    if (truncated && full) {
      const isTruncatedVisible = truncated.style.display !== 'none';
      truncated.style.display = isTruncatedVisible ? 'none' : 'block';
      full.style.display = isTruncatedVisible ? 'block' : 'none';
    }
  }
</script>
