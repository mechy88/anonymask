<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sample Anonymask" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <!-- ✅ Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- ✅ Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <!-- Favicon and Icons -->
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- ✅ Rails Assets -->
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="background-color: #F1F5F9">
    <!-- ✅ Navbar -->
    <nav class="navbar navbar-expand-lg py-3 mb-4 shadow-sm bg-light" style="height: 150px;">
      <div class="container">
        <!-- Logo aligned left -->
        <%= link_to posts_path, class: "navbar-brand d-flex align-items-center" do %>
          <%= image_tag "Logo.png", class: "img-fluid", style: "max-height: 40px;", alt: "Anonymask Logo" %>
        <% end %>
    
        <!-- Toggler for mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
    
        <!-- Right-aligned buttons -->
        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
          <ul class="navbar-nav align-items-center">
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "+ New Post", new_post_path, class: "btn btn-dark ms-2" %>
              </li>
              <li class="nav-item">
                <%= button_to "Log out", session_path, method: :delete, class: "btn btn-outline-dark ms-2" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Sign Up", new_registration_path, class: "btn btn-outline-dark ms-2" %>
              </li>
              <li class="nav-item">
                <%= link_to "Login", new_session_path, class: "btn btn-outline-dark ms-2" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>


    <!-- ✅ Flash Messages -->
    <div class="container">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
    </div>

    <!-- ✅ Main Content -->
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
